# Copy this file to .env and fill in real values. .env is gitignored;
# never commit real secrets (spec 0.1 rule 9).

# ---------------------------------------------------------------------
# Cloud LLM API keys (spec section 6, ADR-001: all three connect directly
# to official endpoints). Leave a key blank/unset to disable that
# provider — healthz will report it as disabled rather than erroring.
# ---------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ---------------------------------------------------------------------
# Tier routing defaults (spec 6.1). Model IDs only — per-agent overrides
# live in agents.llm_profile (DB), not here. L0/L1 default to local
# Ollama; L2/L3 default to Anthropic. Provider for L2/L3 can be switched
# to openai|gemini|ollama here (values are validated at gateway
# construction; unknown providers fall back to anthropic).
# ---------------------------------------------------------------------
LLM_L0_MODEL=mxbai-embed-large
LLM_L1_MODEL=qwen2.5:7b-instruct
LLM_L2_PROVIDER=anthropic
LLM_L2_MODEL=claude-haiku-4-5
LLM_L3_PROVIDER=anthropic
LLM_L3_MODEL=claude-sonnet-4-5

# ---------------------------------------------------------------------
# Local inference (Ollama on the host machine; engine reaches it via
# host.docker.internal inside compose — see docker-compose.yml).
# ---------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------
DATABASE_URL=postgres://annexb:annexb@localhost:5432/annexb
POSTGRES_USER=annexb
POSTGRES_PASSWORD=annexb
POSTGRES_DB=annexb

# ---------------------------------------------------------------------
# Cost control (spec 6.1: 80% degrade / 100% pause thresholds)
# ---------------------------------------------------------------------
DAILY_BUDGET_USD=2.0

# ---------------------------------------------------------------------
# Resident world source (Phase 1). db = load the most recent seeded
# world from PostgreSQL (compose default); fixture = DB-less demo mode
# loading engine/crates/sim-core/tests/fixtures/world_fixture.json —
# use this on machines without a database. Optional path overrides:
# TMJ_PATH (office_shell.tmj) and FIXTURE_PATH (world fixture JSON)
# default to the in-repo files when unset.
# ---------------------------------------------------------------------
WORLD_SOURCE=fixture

# ---------------------------------------------------------------------
# LLM_MODE=mock forces every LLM call through the deterministic mock
# provider (spec 6.1, success criterion S6 golden-replay). Set to
# anything else (or unset) for real provider calls.
# ---------------------------------------------------------------------
LLM_MODE=mock

# ---------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------
RUST_LOG=info
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
